# Flow Code: VS0-QUAL-BUILD-DOTNET
# Story 7.8.4: .NET Client Library Native Build
# AC-4: MuMain.cpp wraps #include "resource.h" in #ifdef _WIN32 / #endif
#
# RED PHASE: Test FAILS until MuMain.cpp line 27 is changed from:
#     #include "resource.h"
# to:
#     #ifdef _WIN32
#     #include "resource.h"
#     #endif
#
# resource.h is generated by the Windows RC compiler (MSVC) and has no
# cross-platform stub. Without the guard, macOS/Linux builds fail with
# "file not found" on this include.

cmake_minimum_required(VERSION 3.25)

if(NOT DEFINED WINMAIN_CPP)
    set(WINMAIN_CPP "${CMAKE_CURRENT_LIST_DIR}/../../src/source/Main/MuMain.cpp")
endif()

if(NOT EXISTS "${WINMAIN_CPP}")
    message(FATAL_ERROR "AC-4 [7.8.4]: MuMain.cpp does not exist: ${WINMAIN_CPP}")
endif()

file(READ "${WINMAIN_CPP}" WINMAIN_CONTENT)

# --- Check 1: resource.h is still included (not accidentally deleted) ---
string(FIND "${WINMAIN_CONTENT}" "resource.h" _pos_resource)
if(_pos_resource EQUAL -1)
    message(FATAL_ERROR "AC-4 FAIL [7.8.4]: 'resource.h' include not found in MuMain.cpp — it should exist but be guarded by #ifdef _WIN32")
endif()

# --- Check 2: resource.h include is inside a #ifdef _WIN32 block ---
# Verify the pattern: #ifdef _WIN32 ... resource.h ... #endif
# We use a regex to find #ifdef _WIN32 before resource.h occurrence
string(REGEX MATCH "#ifdef _WIN32[^\n]*\n[^\n]*resource\\.h" _match_guarded "${WINMAIN_CONTENT}")
if(NOT _match_guarded)
    # Try the multi-line pattern: #ifdef _WIN32 on its own line, then resource.h on next line
    string(REGEX MATCH "#ifdef _WIN32\r?\n#include \"resource\\.h\"" _match_guarded2 "${WINMAIN_CONTENT}")
    if(NOT _match_guarded2)
        message(FATAL_ERROR "AC-4 FAIL [7.8.4]: '#include \"resource.h\"' is NOT guarded by #ifdef _WIN32 in MuMain.cpp — causes 'file not found' on macOS/Linux builds")
    endif()
endif()

# --- Check 3: Corresponding #endif exists after the guarded include ---
string(REGEX MATCH "#ifdef _WIN32\r?\n#include \"resource\\.h\"\r?\n#endif" _match_full_guard "${WINMAIN_CONTENT}")
if(NOT _match_full_guard)
    # Allow comments between include and endif
    string(REGEX MATCH "#ifdef _WIN32\r?\n#include \"resource\\.h\"" _match_partial "${WINMAIN_CONTENT}")
    if(_match_partial)
        # Check that an #endif appears soon after the resource.h guard (within 500 chars = ~10 lines)
        string(REGEX MATCH "#ifdef _WIN32\r?\n#include \"resource\\.h\".{0,500}#endif" _match_with_endif "${WINMAIN_CONTENT}")
        if(NOT _match_with_endif)
            message(FATAL_ERROR "AC-4 FAIL [7.8.4]: #ifdef _WIN32 found before resource.h but no closing #endif found within reasonable distance")
        endif()
        message(STATUS "AC-4: #ifdef _WIN32 guard present with #endif — OK (allow comment between include and endif)")
    else()
        message(FATAL_ERROR "AC-4 FAIL [7.8.4]: '#include \"resource.h\"' is NOT inside a #ifdef _WIN32 / #endif block in MuMain.cpp")
    endif()
endif()

# --- Check 4: No bare (unguarded) #include "resource.h" outside #ifdef _WIN32 ---
# The content before the first #ifdef _WIN32 must not contain resource.h
string(FIND "${WINMAIN_CONTENT}" "#ifdef _WIN32" _pos_first_guard)
string(FIND "${WINMAIN_CONTENT}" "resource.h" _pos_first_resource)
if(_pos_first_resource LESS _pos_first_guard)
    message(FATAL_ERROR "AC-4 FAIL [7.8.4]: 'resource.h' include appears BEFORE '#ifdef _WIN32' guard — include is unguarded")
endif()

# --- Check 5: IDI_ICON1 fallback definition exists in PlatformCompat.h ---
# AC-4 implies that symbols like IDI_ICON1 (used in MuMain.cpp) must have cross-platform fallback definitions
set(PLATFORM_COMPAT_H "${CMAKE_CURRENT_LIST_DIR}/../../src/source/Platform/PlatformCompat.h")
if(EXISTS "${PLATFORM_COMPAT_H}")
    file(READ "${PLATFORM_COMPAT_H}" COMPAT_CONTENT)
    # Look for IDI_ICON1 fallback definition (e.g., #define IDI_ICON1 1)
    if(COMPAT_CONTENT MATCHES "IDI_ICON1")
        message(STATUS "AC-4: IDI_ICON1 fallback definition found in PlatformCompat.h — OK")
    else()
        message(FATAL_ERROR "AC-4 FAIL [7.8.4]: IDI_ICON1 fallback definition NOT found in PlatformCompat.h — cross-platform builds will fail when accessing resource symbols")
    endif()
else()
    message(WARNING "AC-4: PlatformCompat.h not found at ${PLATFORM_COMPAT_H} — skipping IDI_ICON1 check (non-critical)")
endif()

message(STATUS "AC-4 PASS [7.8.4]: MuMain.cpp '#include \"resource.h\"' is wrapped in #ifdef _WIN32 / #endif guard — cross-platform builds safe")
