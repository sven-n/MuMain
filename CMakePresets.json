{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "description": "Base configuration for Windows builds (MSVC)",
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-x86",
      "displayName": "Windows x86",
      "description": "Standard build without editor features",
      "inherits": "windows-base",
      "architecture": {
        "value": "x86",
        "strategy": "external"
      },
      "toolchainFile": "${sourceDir}/toolchain-x86.cmake",
      "cacheVariables": {
        "ENABLE_EDITOR": "OFF"
      }
    },
    {
      "name": "windows-x86-mueditor",
      "displayName": "Windows x86 MuEditor",
      "description": "Build with editor features",
      "inherits": "windows-base",
      "architecture": {
        "value": "x86",
        "strategy": "external"
      },
      "toolchainFile": "${sourceDir}/toolchain-x86.cmake",
      "cacheVariables": {
        "ENABLE_EDITOR": "ON"
      }
    },
    {
      "name": "windows-x64",
      "displayName": "Windows x64",
      "description": "Standard build without editor features",
      "inherits": "windows-base",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "toolchainFile": "${sourceDir}/toolchain-x64.cmake",
      "cacheVariables": {
        "ENABLE_EDITOR": "OFF"
      }
    },
    {
      "name": "windows-x64-mueditor",
      "displayName": "Windows x64 MuEditor",
      "description": "Build with editor features",
      "inherits": "windows-base",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "toolchainFile": "${sourceDir}/toolchain-x64.cmake",
      "cacheVariables": {
        "ENABLE_EDITOR": "ON"
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "description": "Base configuration for native Linux builds",
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "MU_ENABLE_DOTNET": "OFF",
        "BUILD_TESTING": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-x64",
      "displayName": "Linux x86_64",
      "description": "Native Linux x64 build — full build target, must compile and pass tests",
      "inherits": "linux-base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/linux-x64.cmake",
      "cacheVariables": {
        "ENABLE_EDITOR": "OFF"
      }
    },
    {
      "name": "macos-base",
      "hidden": true,
      "description": "Base configuration for native macOS builds",
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "MU_ENABLE_DOTNET": "OFF",
        "BUILD_TESTING": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "macos-arm64",
      "displayName": "macOS arm64",
      "description": "Native macOS Apple Silicon build — full build target, must compile and pass tests",
      "inherits": "macos-base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/macos-arm64.cmake",
      "cacheVariables": {
        "ENABLE_EDITOR": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x86-debug",
      "displayName": "x86 Debug",
      "configurePreset": "windows-x86",
      "configuration": "Debug"
    },
    {
      "name": "windows-x86-release",
      "displayName": "x86 Release",
      "configurePreset": "windows-x86",
      "configuration": "Release"
    },
    {
      "name": "windows-x86-mueditor-debug",
      "displayName": "x86 MuEditor Debug",
      "configurePreset": "windows-x86-mueditor",
      "configuration": "Debug"
    },
    {
      "name": "windows-x86-mueditor-release",
      "displayName": "x86 MuEditor Release",
      "configurePreset": "windows-x86-mueditor",
      "configuration": "Release"
    },
    {
      "name": "windows-x64-debug",
      "displayName": "x64 Debug",
      "configurePreset": "windows-x64",
      "configuration": "Debug"
    },
    {
      "name": "windows-x64-release",
      "displayName": "x64 Release",
      "configurePreset": "windows-x64",
      "configuration": "Release"
    },
    {
      "name": "windows-x64-mueditor-debug",
      "displayName": "x64 MuEditor Debug",
      "configurePreset": "windows-x64-mueditor",
      "configuration": "Debug"
    },
    {
      "name": "windows-x64-mueditor-release",
      "displayName": "x64 MuEditor Release",
      "configurePreset": "windows-x64-mueditor",
      "configuration": "Release"
    },
    {
      "name": "linux-x64-debug",
      "displayName": "Linux x64 Debug",
      "configurePreset": "linux-x64",
      "configuration": "Debug"
    },
    {
      "name": "linux-x64-release",
      "displayName": "Linux x64 Release",
      "configurePreset": "linux-x64",
      "configuration": "Release"
    },
    {
      "name": "macos-arm64-debug",
      "displayName": "macOS arm64 Debug",
      "configurePreset": "macos-arm64",
      "configuration": "Debug"
    },
    {
      "name": "macos-arm64-release",
      "displayName": "macOS arm64 Release",
      "configurePreset": "macos-arm64",
      "configuration": "Release"
    }
  ]
}
